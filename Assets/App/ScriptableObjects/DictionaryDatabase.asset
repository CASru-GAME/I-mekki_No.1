  m_Name: DictionaryDatabase
  m_EditorClassIdentifier: Assembly-CSharp::App.Scripts.Title.DictionaryDatabase
  _items:
  - title: "1. \u3081\u3063\u304D\u3068\u306F\uFF1F"
    description: "\u300C\u3081\u3063\u304D\u300D\u306F\u7D20\u6750\u306E\u8868\u9762\u306B\u91D1\u5C5E\u306B\u3088\u308B\u8584\u3044\u819C\u3092\u4F5C\u308B\u3053\u3068\u3067\u3001\u7D20\u6750\u306B\u65B0\u3057\u3044\u6A5F\u80FD\u3092\u4E0E\u3048\u308B\u6280\u8853\u3067\u3059\u3002\n\u8EAB\u306E\u56DE\u308A\u306E\u305F\u304F\u3055\u3093\u306E\u88FD\u54C1\u306B\u4F7F\u308F\u308C\u3066\u3044\u307E\u3059\u3002"
  - title: "2. \u3081\u3063\u304D\u306E\u5F79\u5272"
    description: "\u3081\u3063\u304D\u5C4B\u3055\u3093\u306F\u300C\u91D1\u5C5E\u306E\u30AF\u30EA\u30FC\u30CB\u30F3\u30B0\u5C4B\u3055\u3093\u300D\u3002\n\u6CB9\u306E\u6C5A\u308C\u3092\u6D17\u6D44\u3057\u3001\u305D\u306E\u4E0A\u306B\u65B0\u3057\u3044\u819C\u3092\u4F5C\u308B\u3053\u3068\u3067\u3001\u3088\u308A\u304D\u308C\u3044\u306A\u72B6\u614B\u306E\u88FD\u54C1\u3092\u304A\u8FD4\u3057\u3059\u308B\u304A\u4ED5\u4E8B\u3067\u3059\u3002"
  - title: "3. \u9632\u98DF\u6027"
    description: "\u3081\u3063\u304D\u306F\u88FD\u54C1\u3092\u30B5\u30D3\u304B\u3089\u5B88\u308A\u307E\u3059\u3002\n\u3081\u3063\u304D\u306B\u3088\u3063\u3066\u3001\u540C\u3058\u3082\u306E\u3092\u3088\u308A\u9577\u304F\u5B89\u5168\u306B\u5229\u7528\u3067\u304D\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002"
  - title: "4. \u88C5\u98FE\u6027\u30FB\u8010\u98DF\u6027"
    description: "\u3081\u3063\u304D\u306F\u88FD\u54C1\u306E\u898B\u305F\u76EE\u3092\u30D4\u30AB\u30D4\u30AB\u306B\u3057\u305F\u308A\u3001\u9178\u3084\u5869\u5206\u306B\u5F37\u304F\u3057\u305F\u308A\u3057\u307E\u3059\u3002\n\u3053\u306E\u7279\u5FB4\u306F\u3001\u8ECA\u3084\u30D0\u30A4\u30AF\u3068\u3044\u3063\u305F\u88FD\u54C1\u306B\u5229\u7528\u3055\u308C\u3066\u3044\u307E\u3059\u3002"
  - title: "5. \u306F\u3093\u3060\u4ED8\u3051\u6027\u30FB\u6F64\u6ED1\u6027"
    description: "\u3081\u3063\u304D\u306B\u3088\u308A\u306F\u3093\u3060\u4ED8\u3051\u3092\u3057\u3084\u3059\u304F\u3067\u304D\u307E\u3059\u3002\n\u307E\u305F\u3001\u91D1\u5C5E\u306E\u9593\u3092\u3059\u3079\u308A\u3084\u3059\u304F\u3059\u308B\u3053\u3068\u3067\u3001\u6A5F\u68B0\u306E\u6027\u80FD\u3092\u4E0A\u3052\u308B\u3053\u3068\u3082\u3067\u304D\u307E\u3059\u3002"
  - title: "6. \u6297\u83CC\u6027"
    description: "\u9280\u306B\u3088\u308B\u3081\u3063\u304D\u306F\u7D30\u83CC\u3084\u30A6\u30A4\u30EB\u30B9\u306E\u5897\u52A0\u3092\u9632\u3050\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002\n\u3088\u308A\u5B89\u5168\u306A\u88FD\u54C1\u306E\u958B\u767A\u306B\u5F79\u7ACB\u3061\u307E\u3059\u3002"
  - title: "7. \u96FB\u6C17\u7279\u6027"
    description: "\u91D1\u306B\u3088\u308B\u3081\u3063\u304D\u306F\u96FB\u6C17\u3092\u6D41\u308C\u3084\u3059\u304F\u3057\u307E\u3059\u3002\n\u3081\u3063\u304D\u51E6\u7406\u306B\u3088\u308A\u7279\u6027\u304C\u5909\u308F\u308B\u3053\u3068\u3067\u3001\u3088\u308A\u88FD\u54C1\u306E\u5E45\u304C\u5E83\u304C\u308A\u307E\u3059\u3002"
  - title: "8. \u8010\u4E45\u6027\u30FB\u8010\u6469\u8017\u6027"
    description: "\u786C\u8CEA\u30AF\u30ED\u30E0\u306B\u3088\u308B\u3081\u3063\u304D\u306F\u7D20\u6750\u3092\u6469\u64E6\u3057\u306B\u304F\u304F\u3001\u786C\u3044\u7D20\u6750\u306B\u3057\u307E\u3059\u3002\n\u3081\u3063\u304D\u306B\u3088\u3063\u3066\u3088\u308A\u5F37\u3044\u90E8\u54C1\u3092\u4F5C\u308B\u3053\u3068\u304C\u53EF\u80FD\u306B\u306A\u308A\u307E\u3059\u3002"
  - title: "9. \u3081\u3063\u304D\u306E\u7A2E\u985E"
    description: "\u30CB\u30C3\u30B1\u30EB\u3001\u4E9C\u925B\u3001\u3059\u305A\u3001\u9285\u306A\u3069\u69D8\u3005\u306A\u91D1\u5C5E\u304C\u3081\u3063\u304D\u306B\u306F\u5229\u7528\u3055\u308C\u307E\u3059\u3002\n\u4F7F\u3046\u91D1\u5C5E\u306B\u3088\u3063\u3066\u7D20\u6750\u306B\u4E0E\u3048\u308B\u3053\u3068\u304C\u3067\u304D\u308B\u6A5F\u80FD\u306F\u5909\u5316\u3057\u307E\u3059\u3002"
  - title: "10. \u3081\u3063\u304D\u306E\u4ED5\u65B9"
    description: "\u96FB\u6C17\u3092\u5E2F\u3073\u305F\u539F\u5B50\u3067\u3042\u308B\u30A4\u30AA\u30F3\u304C\u542B\u307E\u308C\u305F\u6DB2\u4F53\u306B\u88FD\u54C1\u3092\u5165\u308C\u308B\u3053\u3068\u3067\u3001\u5916\u5074\u306B\u65B0\u305F\u306A\u8584\u3044\u819C\u3092\u4F5C\u308A\u307E\u3059\u3002\n\u3053\u306E\u8584\u3044\u819C\u304C\u3081\u3063\u304D\u3068\u306A\u308A\u3001\u88FD\u54C1\u3092\u3088\u308A\u5F37\u304F\u3057\u307E\u3059\u3002"
  - title: "11. \u3081\u3063\u304D\u306E\u305F\u3081\u306E\u9053\u5177"
    description: "\u672C\u6587"
  - title: "12. \u3081\u3063\u304D\u306E\u8A9E\u6E90"
    description: "\u300C\u3081\u3063\u304D\u300D\u306F\u65E5\u672C\u8A9E\u306E\u8A00\u8449\u3067\u3059\u3002\u6F22\u5B57\u306E\u66F8\u304D\u65B9\u306F\u300C\u6EC5\u91D1\u2192\u5857\u91D1\u2192\u934D\u91D1\u300D\u3068\u5909\u5316\u3057\u3066\u304D\u307E\u3057\u305F\u3002\n\u88FD\u54C1\u306B\u91D1\u5C5E\u8584\u3044\u819C\u3092\u5F35\u308B\u3068\u3044\u30A4\u30E1\u30FC\u30B8\u306B\u3074\u3063\u305F\u308A\u3067\u3059\u3002"
  - title: "13. \u77F3\u5DDD\u30E1\u30C3\u30AD\u3063\u3066\uFF1F"
    description: "\u77F3\u5DDD\u770C\u91D1\u6CA2\u5E02\u91D1\u77F3\u306B\u672C\u793E\u304C\u3042\u308B\u3081\u3063\u304D\u52A0\u5DE5\u3092\u884C\u3046\u4F1A\u793E\u3067\u3059\u3002\nQCD(\u30AF\u30AA\u30EA\u30C6\u30A3\u30FB\u30B3\u30B9\u30C8\u30FB\u30C7\u30EA\u30D0\u30EA\u30FC)\u3092\u5411\u4E0A\u3092\u76EE\u6307\u3057\u3001\u304A\u5BA2\u69D8\u306B\u6E80\u8DB3\u3057\u3066\u3082\u3089\u3046\u305F\u3081\u65E5\u3005\u52AA\u529B\u3057\u3066\u3044\u307E\u3059\u3002"
  - title: "14. \u77F3\u5DDD\u30E1\u30C3\u30AD\u306E\u601D\u3044"
    description: "\u77F3\u5DDD\u30E1\u30C3\u30AD\u306F\u5F93\u696D\u54E1\u3068\u305D\u306E\u5BB6\u65CF\u306E\u5E78\u305B\u3092\u5927\u5207\u306B\u3057\u3066\u3044\u307E\u3059\u3002\u304A\u5BA2\u69D8\u304B\u3089\u306E\u4FE1\u983C\u3060\u3051\u3067\u306A\u304F\u3001\u5F93\u696D\u54E1\u304C\u751F\u304D\u751F\u304D\u3068\u50CD\u3051\u308B\u74B0\u5883\u3092\u5B88\u308A\u7D9A\u3051\u3089\u308C\u308B\u4F1A\u793E\u3092\u76EE\u6307\u3057\u3066\u3044\u307E\u3059\u3002"
  - title: "15. \u77F3\u5DDD\u30E1\u30C3\u30AD\u306E\u6B74\u53F2"
    description: "\u77F3\u5DDD\u30E1\u30C3\u30AD\u306F\u662D\u548C35\u5E74\u306B\u5275\u696D\u3057\u305F\u3001\u6B74\u53F2\u3042\u308B\u4F1A\u793E\u3067\u3059\u3002\n\u5275\u696D\u5F53\u6642\u304B\u3089\u306E\u6280\u8853\u3092\u5B88\u308A\u7D9A\u3051\u308B\u3068\u3068\u3082\u306B\u66F4\u306A\u308B\u5DE5\u592B\u30FB\u6539\u5584\u306B\u53D6\u308A\u7D44\u3093\u3067\u3044\u307E\u3059\u3002"
  - title: "16. \u4E3B\u4EBA\u516C\u306B\u3064\u3044\u3066"
    description: "\u91D1\u77F3\u590F\u796D\u308A\u306E\u4F1D\u7D71\u884C\u4E8B\u3067\u3042\u308B\u300C\u60AA\u9B54\u7953\u3044\u300D\u304C\u30E2\u30C1\u30FC\u30D5\u306E\u9B3C\u306E\u59FF\u3092\u3057\u3066\u3044\u307E\u3059\u3002\n\u4F5C\u696D\u7740\u3092\u7740\u3066\u3001\u624B\u306B\u306F\u3081\u3063\u304D\u306E\u305F\u3081\u306E\u9053\u5177\u3092\u6301\u3063\u3066\u3044\u307E\u3059\u3002"
  - title: "17. \u30B5\u30EB\u306B\u3064\u3044\u3066"
    description: "\u672C\u6587"
  - title: "18. \u30A4\u30CC\u306B\u3064\u3044\u3066"
    description: "\u672C\u6587"
  - title: "19. \u30AD\u30B8\u306B\u3064\u3044\u3066"
    description: "\u672C\u6587"
  - title: "20. \u3053\u306E\u30B9\u30C6\u30FC\u30B8\u3063\u3066\uFF1F"
    description: "\u672C\u6587"
  - title: "21. \u4E3B\u4EBA\u516C\u306E\u5192\u967A"
    description: "\u672C\u6587"
